# All Events - Production Environment
# Copy to .env before running docker-compose

# Database
DB_PASSWORD=super_secure_password_change_me

# Site (внешний URL, под которым доступно приложение)
# При использовании субпути /events/ на сервере 138.124.70.3:
SITE_URL=http://138.124.70.3/site-all-events

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# App
DEBUG=false
