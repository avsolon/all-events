# Scraper Microservice for All Events
# Copy to .env and fill in values

# URL основного API (All Events website)
API_URL=http://138.124.70.3/site-all-events/api/events/upsert

# API ключ (должен совпадать с SCRAPER_API_KEY в .env основного проекта)
